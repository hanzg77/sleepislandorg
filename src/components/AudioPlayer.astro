---
interface Props {
  src: string;
  title: string;
  lang?: 'zh-Hans' | 'en';
  autoplay?: boolean;
}
const { src, title, lang = 'zh-Hans', autoplay = false } = Astro.props;
const isEn = lang === 'en';
const label = isEn ? `Play preview: ${title}` : `试听：${title}`;
---

<div class="bg-[var(--color-bg-card)] border border-white/[0.06] rounded-2xl p-5 md:p-6">
  <audio
    id="audio-player"
    controls
    preload="auto"
    class="w-full"
    aria-label={label}
  >
    <source src={src} type="audio/mpeg" />
    <source src={src} type="audio/mp4" />
    {isEn ? 'Your browser does not support audio playback.' : '你的浏览器不支持音频播放。'}
  </audio>
  <p class="text-[12px] text-[var(--color-text-muted)] mt-2.5">
    {isEn
      ? 'Preview clip. Full version with auto-stop in the app.'
      : '试听片段，完整版请在 App 内播放，支持入睡自动停止。'}
  </p>
</div>

<script>
  // Auto-play when arriving from a 试听 link or if hash is #play
  const audio = document.getElementById('audio-player') as HTMLAudioElement;
  if (audio) {
    const shouldAutoplay = document.referrer.includes('/resources') ||
      window.location.hash === '#play' ||
      document.referrer.includes('sleepisland.org');
    if (shouldAutoplay) {
      // Small delay to ensure page is ready, then attempt play
      setTimeout(() => {
        audio.play().catch(() => {
          // Browser blocked autoplay — user will click manually
        });
      }, 300);
    }
  }
</script>
