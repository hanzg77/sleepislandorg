---
import { UI, type Lang } from '../data/i18n';

interface Props {
  lang?: Lang;
  variant?: 'hero' | 'mid' | 'bottom';
}
const { lang = 'zh-Hans', variant = 'bottom' } = Astro.props;
const t = UI[lang];
---

<aside class={`text-center ${variant === 'hero' ? 'py-8' : 'py-12 px-4'}`}>
  {variant !== 'hero' && (
    <div class="max-w-xl mx-auto">
      <h2 class="text-2xl font-bold mb-3">{t.ctaHeading}</h2>
      <p class="text-[var(--color-text-secondary)] mb-6">{t.ctaSub}</p>
    </div>
  )}
  <a
    href="https://apps.apple.com/app/id6747609991"
    class="inline-block bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white font-medium px-8 py-3.5 rounded-full transition-colors text-base"
  >
    {t.ctaBtn}
  </a>
</aside>
