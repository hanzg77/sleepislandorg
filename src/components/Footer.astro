---
import { UI, type Lang } from '../data/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'zh-Hans' } = Astro.props;
const t = UI[lang];
const prefix = lang === 'zh-Hans' ? '' : lang === 'en' ? '/en' : `/${lang}`;
---

<footer class="border-t border-[var(--color-border-card)] mt-16">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <div class="flex flex-col sm:flex-row justify-between gap-8">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/assets/logo-new-1024.png" alt={t.brandName} width="28" height="28" class="rounded-lg" />
          <span class="font-bold">{t.brandName}</span>
        </div>
        <p class="text-sm text-[var(--color-text-secondary)] max-w-xs">{t.footerDesc}</p>
      </div>

      <div class="flex gap-12 text-sm">
        <div>
          <h3 class="font-semibold mb-3">{t.footerPages}</h3>
          <ul class="space-y-2 text-[var(--color-text-secondary)]">
            <li><a href={`${prefix}/resources/`} class="hover:text-white transition-colors">{t.footerSounds}</a></li>
            <li><a href={`${prefix}/snore-detection/`} class="hover:text-white transition-colors">{t.footerSnore}</a></li>
            <li><a href={`${prefix}/tinnitus-relief/`} class="hover:text-white transition-colors">{t.footerTinnitus}</a></li>
            <li><a href={`${prefix}/guides/`} class="hover:text-white transition-colors">{t.footerGuides}</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold mb-3">{t.footerLegal}</h3>
          <ul class="space-y-2 text-[var(--color-text-secondary)]">
            <li><a href={`${prefix}/privacy/`} class="hover:text-white transition-colors">{t.footerPrivacy}</a></li>
            <li><a href={`${prefix}/terms/`} class="hover:text-white transition-colors">{t.footerTerms}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-[var(--color-border-card)] flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-[var(--color-text-muted)]">
      <span>&copy; 2026 {t.brandName}. All rights reserved.</span>
      <a href="mailto:contact@sleepisland.org" class="hover:text-[var(--color-text-secondary)] transition-colors">contact@sleepisland.org</a>
    </div>
  </div>
</footer>
