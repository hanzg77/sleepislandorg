---
import { UI, type Lang } from '../data/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'zh-Hans' } = Astro.props;
const t = UI[lang];
const prefix = lang === 'zh-Hans' ? '' : lang === 'en' ? '/en' : `/${lang}`;
---

<footer class="border-t border-white/[0.06] mt-20 bg-[var(--color-bg-primary)]">
  <div class="max-w-[980px] mx-auto px-5 py-12 md:py-14">
    <div class="flex flex-col sm:flex-row justify-between gap-10">
      <div class="max-w-[280px]">
        <div class="flex items-center gap-2.5 mb-3">
          <img src="/assets/logo-new-1024.png" alt={t.brandName} width="28" height="28" class="rounded-[7px]" />
          <span class="font-semibold text-[15px] text-white">{t.brandName}</span>
        </div>
        <p class="text-[13px] text-[var(--color-text-secondary)] leading-relaxed">{t.footerDesc}</p>
      </div>

      <div class="flex gap-16 text-[13px]">
        <div>
          <h3 class="font-semibold text-[12px] uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t.footerPages}</h3>
          <ul class="space-y-2.5 text-[var(--color-text-secondary)]">
            <li><a href={`${prefix}/resources/`} class="hover:text-white transition-colors duration-300">{t.footerSounds}</a></li>
            <li><a href={`${prefix}/snore-detection/`} class="hover:text-white transition-colors duration-300">{t.footerSnore}</a></li>
            <li><a href={`${prefix}/tinnitus-relief/`} class="hover:text-white transition-colors duration-300">{t.footerTinnitus}</a></li>
            <li><a href={`${prefix}/guides/`} class="hover:text-white transition-colors duration-300">{t.footerGuides}</a></li>
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-[12px] uppercase tracking-wider text-[var(--color-text-muted)] mb-4">{t.footerLegal}</h3>
          <ul class="space-y-2.5 text-[var(--color-text-secondary)]">
            <li><a href={`${prefix}/privacy/`} class="hover:text-white transition-colors duration-300">{t.footerPrivacy}</a></li>
            <li><a href={`${prefix}/terms/`} class="hover:text-white transition-colors duration-300">{t.footerTerms}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/[0.06] flex flex-col sm:flex-row justify-between items-center gap-3 text-[12px] text-[var(--color-text-muted)]">
      <span>&copy; 2026 {t.brandName}. All rights reserved.</span>
      <a href="mailto:contact@sleepisland.org" class="hover:text-[var(--color-text-secondary)] transition-colors duration-300">contact@sleepisland.org</a>
    </div>
  </div>
</footer>
