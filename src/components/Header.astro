---
import { LANGS, UI, type Lang } from '../data/i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'zh-Hans' } = Astro.props;
const t = UI[lang];
const prefix = lang === 'zh-Hans' ? '' : lang === 'en' ? '/en' : `/${lang}`;

const nav = [
  { label: t.navSounds, href: `${prefix}/resources/` },
  { label: t.navSnore, href: `${prefix}/snore-detection/` },
  { label: t.navTinnitus, href: `${prefix}/tinnitus-relief/` },
  { label: t.navFaq, href: `${prefix}/faq/` },
];

const homeHref = prefix ? `${prefix}/` : '/';
const currentLangLabel = LANGS.find(l => l.code === lang)?.label || '中文';
---

<header class="sticky top-0 z-50 bg-[rgba(0,0,0,0.72)] backdrop-blur-2xl backdrop-saturate-[180%] border-b border-white/[0.06]">
  <div class="max-w-[980px] mx-auto px-5 h-12 flex items-center justify-between">
    <!-- Logo -->
    <a href={homeHref} class="flex items-center gap-2.5 font-semibold text-[15px] text-[var(--color-text-primary)] hover:text-white transition-colors">
      <img src="/assets/logo-new-1024.png" alt="Sleep Island" width="28" height="28" class="rounded-[7px]" />
      <span class="hidden sm:inline">{t.brandName}</span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-7 text-[13px] text-[var(--color-text-secondary)]">
      {nav.map(item => (
        <a href={item.href} class="hover:text-[var(--color-text-primary)] transition-colors duration-300">{item.label}</a>
      ))}
    </nav>

    <!-- Right side: lang switcher + download -->
    <div class="flex items-center gap-2.5">
      <!-- Language switcher -->
      <div class="relative" id="langSwitcher">
        <button id="langToggle" class="flex items-center gap-1.5 text-[13px] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors duration-300 px-2.5 py-1.5 rounded-full hover:bg-white/[0.06]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <span>{currentLangLabel}</span>
        </button>
        <div id="langDropdown" class="absolute right-0 top-full mt-2 bg-[rgba(28,28,30,0.92)] backdrop-blur-2xl border border-white/[0.1] rounded-2xl py-2 min-w-[160px] shadow-[0_8px_40px_rgba(0,0,0,0.55)] opacity-0 invisible -translate-y-1.5 transition-all duration-200 z-50">
          {LANGS.map(l => (
            <a href={l.prefix ? `${l.prefix}/` : '/'}
               class={`block px-4 py-2 text-[13px] hover:bg-white/[0.06] transition-colors duration-200 ${l.code === lang ? 'text-[var(--color-accent)] font-medium' : 'text-[var(--color-text-secondary)]'}`}>
              {l.label}
            </a>
          ))}
        </div>
      </div>

      <a href="https://apps.apple.com/app/id6747609991"
         class="bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white text-[13px] font-medium px-4 py-1.5 rounded-full transition-colors duration-300">
        {t.navDownload}
      </a>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav class="md:hidden border-t border-white/[0.06] px-5 py-2.5 flex gap-5 overflow-x-auto text-[13px] text-[var(--color-text-secondary)]">
    {nav.map(item => (
      <a href={item.href} class="whitespace-nowrap hover:text-[var(--color-text-primary)] transition-colors duration-300">{item.label}</a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.getElementById('langToggle');
  const dropdown = document.getElementById('langDropdown');
  if (toggle && dropdown) {
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains('opacity-100');
      if (isOpen) {
        dropdown.classList.remove('opacity-100', 'visible', 'translate-y-0');
        dropdown.classList.add('opacity-0', 'invisible', '-translate-y-1.5');
      } else {
        dropdown.classList.remove('opacity-0', 'invisible', '-translate-y-1.5');
        dropdown.classList.add('opacity-100', 'visible', 'translate-y-0');
      }
    });
    document.addEventListener('click', () => {
      dropdown.classList.remove('opacity-100', 'visible', 'translate-y-0');
      dropdown.classList.add('opacity-0', 'invisible', '-translate-y-1.5');
    });
  }
</script>
