---
import CTABanner from './CTABanner.astro';
import ResourceCard from './ResourceCard.astro';
import { UI, getResourceTitle, getScenes, type Lang } from '../data/i18n';
import { resources as allRes } from '../data/resources';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = UI[lang];
const prefix = lang === 'zh-Hans' ? '' : lang === 'en' ? '/en' : `/${lang}`;

// Take top 9 resources by rank (lower rank = higher position), filter out entries without covers
const resources = Object.entries(allRes)
  .filter(([, r]) => r.cover)
  .sort((a, b) => (a[1].rank ?? 99999) - (b[1].rank ?? 99999))
  .slice(0, 12)
  .map(([slug, r]) => ({
    title: getResourceTitle(slug, lang, allRes),
    slug,
    category: r.category,
    scene: getScenes(r.scenes, lang),
    duration: r.durationLabel,
    cover: r.cover,
  }));
---

<!-- Hero with video background -->
<section class="relative overflow-hidden min-h-[280px] md:min-h-[320px]">
  <!-- Video background -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    autoplay muted loop playsinline
    preload="auto"
    poster="/assets/covers/gentle-night-rain.webp"
  >
    <source src="/assets/video/rain-hero.mp4" type="video/mp4" />
  </video>
  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/55"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-transparent to-black/80"></div>

  <div class="relative z-10 max-w-[980px] mx-auto px-5 pt-8 pb-5 md:pt-12 md:pb-7 flex flex-col items-center text-center">
    <!-- Logo + Title -->
    <div class="flex items-center gap-3.5 md:gap-4">
      <div class="relative shrink-0">
        <img
          src="/assets/logo-new-1024.png"
          alt={t.brandName}
          width="56"
          height="56"
          class="relative w-11 h-11 sm:w-12 sm:h-12 md:w-14 md:h-14 rounded-[0.8rem] md:rounded-[1rem] shadow-[0_10px_30px_rgba(0,0,0,0.4)] ring-1 ring-white/[0.08]"
        />
      </div>
      <h1 class="text-[2rem] sm:text-[2.4rem] md:text-[3rem] lg:text-[3.4rem] font-bold tracking-[-0.04em] leading-[1] text-white drop-shadow-[0_2px_8px_rgba(0,0,0,0.3)]">
        {t.brandName}
      </h1>
    </div>
    <!-- Tagline -->
    <p class="mt-2 text-[0.82rem] sm:text-[0.88rem] md:text-[1rem] leading-[1.5] text-white/70 tracking-[0.01em]">
      {t.heroTagline}
    </p>
    <!-- CTA -->
    <div class="mt-4">
      <a
        href="https://apps.apple.com/app/id6747609991"
        class="inline-flex items-center justify-center gap-2 bg-white text-black text-[13px] md:text-[14px] font-semibold px-6 py-2 md:px-7 md:py-2.5 rounded-full transition-all duration-300 hover:bg-white/90 hover:scale-[1.02] active:scale-[0.98]"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        {t.heroCta}
      </a>
    </div>
  </div>

  <!-- Rain sound toggle: bottom-right of hero -->
  <button
    id="rain-toggle"
    class="absolute bottom-3 right-4 z-20 flex items-center gap-1.5 text-white/40 hover:text-white/70 transition-colors duration-300"
    aria-label="Toggle rain sound"
  >
    <!-- Volume off icon (default) -->
    <svg id="rain-icon-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
    <!-- Volume on icon (hidden) -->
    <svg id="rain-icon-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="hidden">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
    </svg>
    <span id="rain-label" class="text-[11px]">🌧</span>
  </button>

  <audio id="ambient-audio" preload="none" loop>
    <source src="https://cdnringbd.shoujiduoduo.com/ringres/aimusic/sleep/audio/vol04_rain_fireplace_2.mp3" type="audio/mpeg" />
  </audio>
</section>

<!-- Featured Resources -->
<section class="max-w-[1060px] mx-auto px-5 pt-4 md:pt-6 pb-16 md:pb-24">
  <div class="text-center mb-8 md:mb-10">
    <h2 class="text-[1.75rem] md:text-[2.5rem] font-bold tracking-[-0.03em] text-white">{t.resourcesTitle}</h2>
    <p class="mt-1.5 text-[15px] md:text-[17px] text-[var(--color-text-secondary)]">{t.resourcesDesc}</p>
  </div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
    {resources.map(r => (
      <ResourceCard {...r} lang={lang} />
    ))}
  </div>
  <div class="text-center mt-10 md:mt-12">
    <a href={`${prefix || ''}/resources/`} class="inline-flex items-center gap-1 text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] text-[15px] font-medium transition-colors duration-300">
      {t.resourcesMore}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- Divider -->
<div class="max-w-[680px] mx-auto border-t border-white/[0.06]"></div>

<!-- Tinnitus Relief -->
<section class="max-w-[680px] mx-auto px-5 py-16 md:py-24">
  <div class="bg-[var(--color-bg-card)] rounded-3xl p-8 md:p-10 border border-white/[0.06] hover:border-white/[0.1] transition-colors duration-500">
    <div class="text-3xl mb-4">&#x1F997;</div>
    <h2 class="text-xl md:text-2xl font-bold tracking-[-0.02em] mb-3 text-white">{t.tinnitusTitle}</h2>
    <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed mb-5">{t.tinnitusDesc}</p>
    <a href={`${prefix || ''}/tinnitus-relief/`} class="inline-flex items-center gap-1 text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] text-[15px] font-medium transition-colors duration-300">
      {t.tinnitusMore}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- Divider -->
<div class="max-w-[680px] mx-auto border-t border-white/[0.06]"></div>

<!-- FAQ -->
<section class="max-w-[680px] mx-auto px-5 py-16 md:py-24">
  <h2 class="text-[1.75rem] md:text-[2.5rem] font-bold tracking-[-0.03em] text-center mb-10 md:mb-14 text-white">{t.faqTitle}</h2>
  <div class="space-y-3">
    <div class="bg-[var(--color-bg-card)] rounded-2xl p-6 md:p-7 border border-white/[0.06] hover:border-white/[0.1] transition-colors duration-500">
      <h3 class="font-semibold text-[15px] md:text-base mb-2 text-white">{t.faq1q}</h3>
      <p class="text-[14px] text-[var(--color-text-secondary)] leading-relaxed">{t.faq1a}</p>
    </div>
    <div class="bg-[var(--color-bg-card)] rounded-2xl p-6 md:p-7 border border-white/[0.06] hover:border-white/[0.1] transition-colors duration-500">
      <h3 class="font-semibold text-[15px] md:text-base mb-2 text-white">{t.faq2q}</h3>
      <p class="text-[14px] text-[var(--color-text-secondary)] leading-relaxed">{t.faq2a}</p>
    </div>
    <div class="bg-[var(--color-bg-card)] rounded-2xl p-6 md:p-7 border border-white/[0.06] hover:border-white/[0.1] transition-colors duration-500">
      <h3 class="font-semibold text-[15px] md:text-base mb-2 text-white">{t.faq3q}</h3>
      <p class="text-[14px] text-[var(--color-text-secondary)] leading-relaxed">{t.faq3a}</p>
    </div>
  </div>
  <div class="text-center mt-8 md:mt-10">
    <a href={`${prefix || ''}/faq/`} class="inline-flex items-center gap-1 text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] text-[15px] font-medium transition-colors duration-300">
      {t.faqMore}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</section>

<!-- Bottom CTA -->
<CTABanner lang={lang} variant="bottom" />

<script>
  const audio = document.getElementById('ambient-audio') as HTMLAudioElement;
  const btn = document.getElementById('rain-toggle');
  const iconOff = document.getElementById('rain-icon-off');
  const iconOn = document.getElementById('rain-icon-on');

  if (audio && btn) {
    audio.volume = 0.2;
    let playing = false;

    btn.addEventListener('click', () => {
      if (playing) {
        audio.pause();
        playing = false;
        iconOff?.classList.remove('hidden');
        iconOn?.classList.add('hidden');
      } else {
        audio.play().then(() => {
          playing = true;
          iconOff?.classList.add('hidden');
          iconOn?.classList.remove('hidden');
        }).catch(() => {});
      }
    });

    // Stop when navigating to detail pages
    document.querySelectorAll('a[href*="/resources/"]').forEach(link => {
      link.addEventListener('click', () => audio.pause());
    });
  }
</script>
