---
import { UI, type Lang } from '../data/i18n';

interface Props {
  title: string;
  slug: string;
  category: string;
  scene: string;
  duration: string;
  cover?: string;
  lang?: Lang;
}
const { title, slug, category, scene, duration, cover, lang = 'zh-Hans' } = Astro.props;
const t = UI[lang];
const prefix = lang === 'zh-Hans' ? '' : lang === 'en' ? '/en' : `/${lang}`;
const href = `${prefix}/resources/${slug}/`;

const fallbackGradient: Record<string, string> = {
  'Rain': 'from-blue-900/80 to-slate-900/80',
  'Nature': 'from-green-900/80 to-emerald-950/80',
  'Fireplace': 'from-orange-900/80 to-amber-950/80',
  'White Noise': 'from-gray-700/80 to-gray-900/80',
  'Tinnitus Relief': 'from-emerald-900/80 to-teal-950/80',
};
const gradient = fallbackGradient[category] || 'from-indigo-900/80 to-slate-900/80';
---

<article class="bg-[var(--color-bg-card)] rounded-2xl overflow-hidden flex flex-col border border-white/[0.06] hover:border-white/[0.12] transition-all duration-500 group hover:shadow-[0_8px_40px_rgba(0,0,0,0.4)]">
  <a href={href} class="block">
    <div class="aspect-video relative overflow-hidden">
      {cover ? (
        <img src={cover} alt={title} class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-700 ease-out" loading="lazy" />
      ) : (
        <div class={`w-full h-full bg-gradient-to-br ${gradient}`}></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
      <span class="absolute top-3 right-3 text-[11px] bg-black/50 backdrop-blur-md text-white/90 px-2.5 py-1 rounded-full font-medium">{duration}</span>
      <span class="absolute bottom-3 left-3.5 text-[11px] text-white/70 font-medium uppercase tracking-wider">{category}</span>
    </div>
  </a>
  <div class="p-4 md:p-5 flex flex-col gap-1.5 flex-1">
    <h3 class="font-semibold text-[14px] md:text-[15px] leading-snug text-white">{title}</h3>
    <p class="text-[13px] text-[var(--color-text-secondary)] line-clamp-1">{scene}</p>
    <div class="flex gap-2.5 mt-auto pt-3">
      <a href={href} class="flex-1 text-center text-[13px] py-2 rounded-xl bg-white/[0.06] text-[var(--color-text-secondary)] hover:bg-white/[0.1] hover:text-white transition-all duration-300 font-medium">
        &#9654; {t.preview}
      </a>
      <a href="https://apps.apple.com/app/id6747609991" class="flex-1 text-center text-[13px] py-2 rounded-xl bg-[var(--color-accent)] hover:bg-[var(--color-accent-hover)] text-white transition-colors duration-300 font-medium">
        {t.fullInApp}
      </a>
    </div>
  </div>
</article>
