---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../data/i18n';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  canonical?: string;
  ogImage?: string;
  alternateZh?: string;
  alternateEn?: string;
  alternateJa?: string;
  alternateEs?: string;
  alternatePt?: string;
  schema?: object[];
}

const {
  title,
  description,
  lang = 'zh-Hans',
  canonical,
  ogImage = '/assets/logo-new-1024.png',
  alternateZh,
  alternateEn,
  alternateJa,
  alternateEs,
  alternatePt,
  schema = []
} = Astro.props;

const siteUrl = 'https://sleepisland.org';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;
const ogLocale = lang === 'en' ? 'en_US' : lang === 'ja' ? 'ja_JP' : lang === 'es' ? 'es_ES' : lang === 'pt' ? 'pt_BR' : 'zh_CN';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/assets/logo-new-1024.png" />

  {alternateZh && <link rel="alternate" hreflang="zh-Hans" href={alternateZh} />}
  {alternateEn && <link rel="alternate" hreflang="en" href={alternateEn} />}
  {alternateJa && <link rel="alternate" hreflang="ja" href={alternateJa} />}
  {alternateEs && <link rel="alternate" hreflang="es" href={alternateEs} />}
  {alternatePt && <link rel="alternate" hreflang="pt" href={alternatePt} />}
  {alternateZh && <link rel="alternate" hreflang="x-default" href={alternateZh} />}

  <meta name="apple-itunes-app" content="app-id=6747609991" />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Sleep Island" />
  <meta property="og:locale" content={ogLocale} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  {schema.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body class="min-h-screen flex flex-col">
  <Header lang={lang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
