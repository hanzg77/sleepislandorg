---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../data/i18n';
import {
  DEFAULT_LANG,
  getAlternateLinks,
  getDefaultAlternateLangs,
  getOgLocale,
  normalizeSchemaData,
  normalizeSeoText,
  normalizeSiteUrl,
  SITE_URL,
} from '../lib/seo';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  canonical?: string;
  ogImage?: string;
  alternateLangs?: Lang[];
  // Deprecated, kept for compatibility with existing pages.
  alternateZh?: string;
  alternateEn?: string;
  alternateJa?: string;
  alternateEs?: string;
  alternatePt?: string;
  schema?: object[];
}

const {
  title,
  description,
  lang = DEFAULT_LANG,
  canonical,
  ogImage = '/assets/logo-new-1024.png',
  alternateLangs,
  schema = []
} = Astro.props;

const alternateLinks = getAlternateLinks(Astro.url.pathname, lang, alternateLangs);
const defaultAlternateLangs = getDefaultAlternateLangs(Astro.url.pathname);
const isLocalizedHome = defaultAlternateLangs.length > 2;
const normalizedTitle = normalizeSeoText(title);
const normalizedDescription = normalizeSeoText(description);
const canonicalUrl = normalizeSiteUrl(canonical || new URL(Astro.url.pathname, SITE_URL).href);
const ogImageUrl = ogImage.startsWith('http') ? normalizeSiteUrl(ogImage) : new URL(ogImage, SITE_URL).href;
const ogLocale = getOgLocale(lang);
const ogAlternateLocales = alternateLinks
  .map(({ lang: alternateLang }) => getOgLocale(alternateLang))
  .filter((locale) => locale !== ogLocale);
const xDefaultLink = alternateLinks.find(({ lang: alternateLang }) => alternateLang === DEFAULT_LANG)?.href ?? canonicalUrl;

const normalizedPageSchema = schema.map((item) => normalizeSchemaData(item));
const getSchemaTypes = (item: unknown): string[] => {
  if (!item || typeof item !== 'object') {
    return [];
  }

  const typeValue = (item as Record<string, unknown>)['@type'];

  if (Array.isArray(typeValue)) {
    return typeValue.filter((value): value is string => typeof value === 'string');
  }

  return typeof typeValue === 'string' ? [typeValue] : [];
};

const pageSchema = normalizedPageSchema.filter((item) => !(isLocalizedHome && getSchemaTypes(item).includes('WebSite')));
const hasOrganizationSchema = pageSchema.some((item) => getSchemaTypes(item).includes('Organization'));

const organizationSchema = hasOrganizationSchema ? null : {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Sleep Island",
  "alternateName": "睡眠岛",
  "url": SITE_URL,
  "logo": `${SITE_URL}/assets/logo-new-1024.png`,
  "email": "contact@sleepisland.org",
  "sameAs": ["https://apps.apple.com/app/id6747609991"]
};

const websiteSchema = isLocalizedHome ? {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Sleep Island",
  "alternateName": "睡眠岛",
  "url": SITE_URL,
  "inLanguage": alternateLinks.map(({ hreflang }) => hreflang)
} : null;

const mergedSchema = [
  ...(organizationSchema ? [organizationSchema] : []),
  ...(websiteSchema ? [websiteSchema] : []),
  ...pageSchema
];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />

  <title>{normalizedTitle}</title>
  <meta name="description" content={normalizedDescription} />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/assets/logo-new-1024.png" />

  {alternateLinks.map(({ hreflang, href }) => (
    <link rel="alternate" hreflang={hreflang} href={href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={xDefaultLink} />

  <meta name="apple-itunes-app" content="app-id=6747609991" />

  <meta property="og:title" content={normalizedTitle} />
  <meta property="og:description" content={normalizedDescription} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Sleep Island" />
  <meta property="og:locale" content={ogLocale} />
  {ogAlternateLocales.map((locale) => (
    <meta property="og:locale:alternate" content={locale} />
  ))}

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={normalizedTitle} />
  <meta name="twitter:description" content={normalizedDescription} />

  {mergedSchema.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body class="min-h-screen flex flex-col">
  <Header lang={lang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
