---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonPage from '../../components/ComparisonPage.astro';
import { COMPARISON_PAGE, COMPARISON_FAQ } from '../../data/comparison';

const lang = 'en' as const;
const cl = 'en' as const;
const pageUrl = 'https://www.sleepisland.org/en/best-free-sleep-apps/';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": COMPARISON_PAGE.title[cl],
    "description": COMPARISON_PAGE.desc[cl],
    "inLanguage": "en",
    "mainEntityOfPage": pageUrl,
    "author": { "@type": "Organization", "name": "Sleep Island", "url": "https://www.sleepisland.org" },
    "publisher": { "@type": "Organization", "name": "Sleep Island", "logo": { "@type": "ImageObject", "url": "https://www.sleepisland.org/assets/logo-new-1024.png" } }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": COMPARISON_FAQ.map((f) => ({
      "@type": "Question",
      "name": f.q[cl],
      "acceptedAnswer": { "@type": "Answer", "text": f.a[cl] }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sleepisland.org/en/" },
      { "@type": "ListItem", "position": 2, "name": COMPARISON_PAGE.title[cl], "item": pageUrl }
    ]
  }
];
---

<BaseLayout title={`${COMPARISON_PAGE.title[cl]} | Sleep Island`} description={COMPARISON_PAGE.desc[cl]} lang={lang} schema={schema}>
  <ComparisonPage lang={lang} />
</BaseLayout>
