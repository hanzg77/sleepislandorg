---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticlePage from '../../../components/ArticlePage.astro';
import { articleFor } from '../../../data/methodology';

const lang = 'en' as const;
const a = articleFor(lang);
const pageUrl = 'https://www.sleepisland.org/en/blog/how-phone-sleep-tracking-works/';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": a.title,
    "description": a.dek,
    "inLanguage": "en",
    "mainEntityOfPage": pageUrl,
    "author": { "@type": "Organization", "name": "Sleep Island", "url": "https://www.sleepisland.org" },
    "publisher": { "@type": "Organization", "name": "Sleep Island", "logo": { "@type": "ImageObject", "url": "https://www.sleepisland.org/assets/logo-new-1024.png" } }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sleepisland.org/en/" },
      { "@type": "ListItem", "position": 2, "name": "Sleep Tracking", "item": "https://www.sleepisland.org/en/sleep-tracking/" },
      { "@type": "ListItem", "position": 3, "name": a.title, "item": pageUrl }
    ]
  }
];
---

<BaseLayout title={`${a.title} | Sleep Island`} description={a.dek} lang={lang} schema={schema}>
  <ArticlePage lang={lang} />
</BaseLayout>
