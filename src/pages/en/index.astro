---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePage from '../../components/HomePage.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sleep Island",
    "url": "https://sleepisland.org/en/",
    "inLanguage": ["en", "zh-Hans", "ja", "es", "pt"]
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Sleep Island",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://sleepisland.org/en/",
    "downloadUrl": "https://apps.apple.com/app/id6747609991"
  }
];
---

<BaseLayout
  title="Sleep Island - Natural Sleep Sounds & Auto-Stop | Sleep Island"
  description="Sleep Island is a sound-driven sleep app: natural soundscapes, tinnitus relief, auto-stop on sleep, and sleep tracking."
  lang="en"
  alternateZh="https://sleepisland.org/"
  alternateEn="https://sleepisland.org/en/"
  alternateJa="https://sleepisland.org/ja/"
  alternateEs="https://sleepisland.org/es/"
  alternatePt="https://sleepisland.org/pt/"
  schema={schema}
>
  <HomePage lang="en" />
</BaseLayout>
