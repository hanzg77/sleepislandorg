---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePage from '../../components/HomePage.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sleep Island",
    "url": "https://www.sleepisland.org/en/",
    "inLanguage": ["en", "zh-Hans", "ja", "es", "pt"]
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Sleep Island",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://www.sleepisland.org/en/",
    "downloadUrl": "https://apps.apple.com/app/id6747609991"
  }
];
---

<BaseLayout
  title="Free iOS Sleep Tracker — Snore Recording, Sleep Sounds, No Wearable | Sleep Island"
  description="Sleep Island is a free iOS sleep tracker that needs no wearable: phone-only sleep tracking, snore & sleep-talk recording, and sleep sounds that auto-stop once you fall asleep."
  lang="en"
  alternateZh="https://www.sleepisland.org/"
  alternateEn="https://www.sleepisland.org/en/"
  alternateJa="https://www.sleepisland.org/ja/"
  alternateEs="https://www.sleepisland.org/es/"
  alternatePt="https://www.sleepisland.org/pt/"
  schema={schema}
>
  <HomePage lang="en" />
</BaseLayout>
