---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AudioPlayer from '../../../components/AudioPlayer.astro';
import CTABanner from '../../../components/CTABanner.astro';
import ResourceCard from '../../../components/ResourceCard.astro';
import { resources } from '../../../data/resources';

export function getStaticPaths() {
  return Object.keys(resources).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const r = resources[slug as string];
if (!r) return Astro.redirect('/en/resources/');

const scenesEn: Record<string, string> = {
  'Sleep': 'Sleep', 'Relaxation': 'Relaxation', 'Reading': 'Reading',
  'Deep Relaxation': 'Deep Relaxation', 'Meditation': 'Meditation',
  'Focus': 'Focus', 'Noise Masking': 'Noise Masking',
  'Tinnitus Relief': 'Tinnitus Relief', 'Sleep Aid': 'Sleep Aid',
  'Morning': 'Morning',
};

const sceneMap: Record<string, string> = {
  '入睡': 'Sleep', '放松': 'Relaxation', '阅读': 'Reading',
  '深度放松': 'Deep Relaxation', '冥想': 'Meditation', '减压': 'Stress Relief',
  '专注': 'Focus', '遮蔽噪音': 'Noise Masking', '失眠': 'Insomnia',
  '耳鸣缓解': 'Tinnitus Relief', '助眠': 'Sleep Aid',
  '早起': 'Morning',
};

const scenesEnList = r.scenes.map((s: string) => sceneMap[s] || s);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "AudioObject",
    "name": r.titleEn,
    "description": `${r.titleEn} - natural sound for sleep and relaxation. Free preview available on web, full version in the Sleep Island app.`,
    "contentUrl": r.audio.startsWith('http') ? r.audio : `https://www.sleepisland.org${r.audio}`,
    "duration": r.duration,
    "inLanguage": ["en", "zh-Hans"],
    "encodingFormat": "audio/mpeg"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sleepisland.org/en/" },
      { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://www.sleepisland.org/en/resources/" },
      { "@type": "ListItem", "position": 3, "name": r.titleEn, "item": `https://www.sleepisland.org/en/resources/${slug}/` }
    ]
  }
];

const relatedResources = r.related.map((s: string) => resources[s]).filter(Boolean).map((rel: any, i: number) => ({
  ...rel,
  slug: r.related[i]
}));
---

<BaseLayout
  title={`${r.titleEn} - Free Preview | Sleep Island`}
  description={`${r.titleEn} - natural sound for sleep and relaxation. Free preview available on web, full version in the Sleep Island app.`}
  lang="en"
  alternateZh={`https://www.sleepisland.org/resources/${slug}/`}
  alternateEn={`https://www.sleepisland.org/en/resources/${slug}/`}
  schema={schema}
>
  <article class="max-w-[680px] mx-auto px-5">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="pt-6 text-[13px] text-[var(--color-text-muted)]">
      <a href="/en/" class="hover:text-[var(--color-text-secondary)] transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/en/resources/" class="hover:text-[var(--color-text-secondary)] transition-colors">Resources</a>
      <span class="mx-2">/</span>
      <span class="text-[var(--color-text-secondary)]">{r.titleEn}</span>
    </nav>

    {r.cover && (
      <div class="mt-6 rounded-2xl overflow-hidden h-48 md:h-64">
        <img src={r.cover} alt={r.titleEn} class="w-full h-full object-cover" loading="eager" />
      </div>
    )}

    <header class="py-10 md:py-12">
      <h1 class="text-[1.75rem] md:text-[2.25rem] font-bold tracking-[-0.02em] mb-4 text-white">{r.titleEn}</h1>
    </header>

    <dl class="summary mb-10" role="contentinfo" aria-label="Resource summary">
      <dt>Type</dt><dd>Sound Preview (Web) + Full Version (App)</dd>
      <dt>Topic</dt><dd>{r.titleEn}</dd>
      <dt>Category</dt><dd>{r.category}</dd>
      <dt>Use Cases</dt><dd>{scenesEnList.join(', ')}</dd>
      <dt>Preview Duration</dt><dd>{r.durationLabel}</dd>
      <dt>App</dt><dd>Sleep Island (iOS)</dd>
      <dt>Download</dt><dd><a href="https://apps.apple.com/app/id6747609991" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">App Store</a></dd>
    </dl>

    <section id="preview" class="mb-12">
      <h2 class="text-xl font-bold mb-5 text-white">Preview</h2>
      <AudioPlayer src={r.audio} title={r.titleEn} lang="en" />
    </section>

    <section id="use-cases" class="mb-12">
      <h2 class="text-xl font-bold mb-5 text-white">Use Cases</h2>
      <ul class="space-y-2.5">
        {scenesEnList.map((s: string) => (
          <li class="flex items-center gap-2.5 text-[14px] text-[var(--color-text-secondary)]">
            <span class="w-1.5 h-1.5 bg-[var(--color-accent)] rounded-full shrink-0"></span>
            {s}
          </li>
        ))}
      </ul>
      <p class="text-[15px] text-[var(--color-text-secondary)] leading-relaxed mt-5">{r.titleEn} - natural sound for sleep and relaxation. Free preview available on web, full version in the Sleep Island app.</p>
    </section>

    <section id="settings" class="mb-12">
      <h2 class="text-xl font-bold mb-5 text-white">Recommended Settings</h2>
      <div class="bg-[var(--color-bg-card)] border border-white/[0.06] rounded-2xl p-6 md:p-7 space-y-3.5 text-[14px] text-[var(--color-text-secondary)] leading-relaxed">
        <p><strong class="text-white">Volume:</strong> Adjust to a comfortable level, recommended below 60 dB</p>
        <p><strong class="text-white">Headphones:</strong> Use comfortable headphones or a bedside speaker</p>
        <p><strong class="text-white">Auto-stop on sleep:</strong> Enable in the app to automatically stop playback when you fall asleep</p>
      </div>
    </section>

    <aside class="mb-12">
      <CTABanner lang="en" variant="mid" />
    </aside>

    <nav aria-label="Related sounds" class="py-12 md:py-14">
      <h2 class="text-xl font-bold mb-6 text-white">Related Sounds</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {relatedResources.map((rel: any) => (
          <ResourceCard title={rel.titleEn} slug={rel.slug} category={rel.category} scene={scenesEn[sceneMap[rel.scenes[0]]] || rel.scenes[0]} duration={rel.durationLabel} cover={rel.cover} lang="en" />
        ))}
      </div>
    </nav>
  </article>

  <CTABanner lang="en" variant="bottom" />
</BaseLayout>
