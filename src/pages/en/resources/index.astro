---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ResourceCard from '../../../components/ResourceCard.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { resources } from '../../../data/resources';

const sceneMap: Record<string, string> = {
  '入睡': 'Sleep', '放松': 'Relaxation', '阅读': 'Reading',
  '深度放松': 'Deep Relaxation', '冥想': 'Meditation', '减压': 'Stress Relief',
  '专注': 'Focus', '遮蔽噪音': 'Noise Masking', '失眠': 'Insomnia',
  '耳鸣缓解': 'Tinnitus Relief', '助眠': 'Sleep Aid', '早起': 'Morning',
};

const allResources = Object.entries(resources).map(([slug, r]) => ({
  title: r.titleEn,
  slug,
  category: r.category,
  scene: r.scenes.map((s: string) => sceneMap[s] || s).join(', '),
  duration: r.durationLabel,
  cover: r.cover,
}));

const categories = ['All', ...new Set(allResources.map(r => r.category))];
---

<BaseLayout
  title="Sound Resources - Free Preview | Sleep Island"
  description="Sleep Island sound resources: rain, nature, fireplace, white noise, tinnitus relief audio. Preview on the web, full version in the app."
  lang="en"
  alternateZh="https://www.sleepisland.org/resources/"
  alternateEn="https://www.sleepisland.org/en/resources/"
>
  <section class="max-w-[1060px] mx-auto px-5 py-16 md:py-20">
    <h1 class="text-[2rem] md:text-[2.5rem] font-bold tracking-[-0.03em] text-center mb-3 text-white">Sound Resources</h1>
    <p class="text-center text-[15px] text-[var(--color-text-secondary)] mb-10">Preview on web, full version in App with auto-stop on sleep</p>

    <div class="flex gap-2 overflow-x-auto pb-4 mb-10" role="tablist">
      {categories.map((cat, i) => (
        <button
          class={`px-4 py-2 rounded-full text-[13px] whitespace-nowrap transition-all duration-300 font-medium ${i === 0 ? 'bg-white text-black' : 'bg-white/[0.06] text-[var(--color-text-secondary)] hover:bg-white/[0.1] hover:text-white'}`}
          role="tab"
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6" id="resource-grid">
      {allResources.map(r => (
        <div data-category={r.category}>
          <ResourceCard {...r} lang="en" />
        </div>
      ))}
    </div>

    <CTABanner lang="en" variant="bottom" />
  </section>

  <script>
    document.querySelectorAll('[role="tab"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category');
        document.querySelectorAll('[role="tab"]').forEach(b => {
          b.className = b === btn
            ? 'px-4 py-2 rounded-full text-[13px] whitespace-nowrap transition-all duration-300 font-medium bg-white text-black'
            : 'px-4 py-2 rounded-full text-[13px] whitespace-nowrap transition-all duration-300 font-medium bg-white/[0.06] text-[var(--color-text-secondary)] hover:bg-white/[0.1] hover:text-white';
        });
        document.querySelectorAll('#resource-grid > div').forEach(card => {
          (card as HTMLElement).style.display = (cat === 'All' || card.getAttribute('data-category') === cat) ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>
