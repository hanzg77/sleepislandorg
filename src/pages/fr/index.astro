---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePage from '../../components/HomePage.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Sleep Island",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://www.sleepisland.org/fr/",
    "downloadUrl": "https://apps.apple.com/app/id6747609991"
  }
];
---

<BaseLayout
  title="Sleep Island - Sons naturels pour dormir · Arrêt automatique"
  description="Sleep Island est une app de sommeil avec sons naturels, arrêt automatique, détection des ronflements et analyse du sommeil."
  lang="fr"
  alternateZh="https://www.sleepisland.org/"
  alternateEn="https://www.sleepisland.org/en/"
  alternateJa="https://www.sleepisland.org/ja/"
  alternateEs="https://www.sleepisland.org/es/"
  alternatePt="https://www.sleepisland.org/pt/" 
  schema={schema}
>
  <HomePage lang="fr" />
</BaseLayout>
