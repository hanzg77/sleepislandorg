---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ResourceDetailPage from '../../../components/ResourceDetailPage.astro';
import { resources } from '../../../data/resources';
import { getResourceTitle, getResourceDescription } from '../../../data/i18n';

export function getStaticPaths() {
  return Object.keys(resources).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const r = resources[slug as string];
const lang = 'hi' as const;
if (!r) return Astro.redirect(`/${lang}/resources/`);
const title = getResourceTitle(slug as string, lang, resources);
---

<BaseLayout
  title={`${title} | Sleep Island`}
  description={getResourceDescription(slug as string, lang, resources)}
  lang={lang}
>
  <ResourceDetailPage slug={slug as string} lang={lang} />
</BaseLayout>
