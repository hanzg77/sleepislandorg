---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePage from '../../components/HomePage.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Sleep Island",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://sleepisland.org/id/",
    "downloadUrl": "https://apps.apple.com/app/id6747609991"
  }
];
---

<BaseLayout
  title="Sleep Island - Suara alam untuk tidur · Auto-stop"
  description="Sleep Island adalah aplikasi tidur dengan suara alam, redakan tinnitus, dan auto-stop."
  lang="id"
  alternateZh="https://sleepisland.org/"
  alternateEn="https://sleepisland.org/en/"
  alternateJa="https://sleepisland.org/ja/"
  alternateEs="https://sleepisland.org/es/"
  alternatePt="https://sleepisland.org/pt/" 
  schema={schema}
>
  <HomePage lang="id" />
</BaseLayout>
