---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomePage from '../components/HomePage.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "睡眠岛 Sleep Island",
    "url": "https://www.sleepisland.org/",
    "inLanguage": ["zh-Hans", "en", "ja", "es", "pt"]
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "睡眠岛 Sleep Island",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://www.sleepisland.org/",
    "downloadUrl": "https://apps.apple.com/app/id6747609991"
  }
];
---

<BaseLayout
  title="睡眠岛 - 自然助眠声音与入睡自动停止 | Sleep Island"
  description="睡眠岛是一款声音驱动的睡眠 App：自然音景、耳鸣缓解、入睡自动停止、鼾声与睡眠记录反馈。"
  lang="zh-Hans"
  alternateZh="https://www.sleepisland.org/"
  alternateEn="https://www.sleepisland.org/en/"
  alternateJa="https://www.sleepisland.org/ja/"
  alternateEs="https://www.sleepisland.org/es/"
  alternatePt="https://www.sleepisland.org/pt/"
  schema={schema}
>
  <HomePage lang="zh-Hans" />
</BaseLayout>
