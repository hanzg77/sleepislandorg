---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePage from '../../components/HomePage.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Sleep Island",
    "url": "https://www.sleepisland.org/ja/",
    "inLanguage": ["ja", "zh-Hans", "en"]
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Sleep Island",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthApplication",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "url": "https://www.sleepisland.org/ja/",
    "downloadUrl": "https://apps.apple.com/app/id6747609991"
  }
];
---

<BaseLayout
  title="Sleep Island - 自然の音で眠る · 自動停止 · 睡眠分析"
  description="Sleep Islandは音で眠りをサポートするアプリ。自然の音景、耳鳴り緩和、入眠自動停止、いびきと睡眠記録。"
  lang="ja"
  alternateZh="https://www.sleepisland.org/"
  alternateEn="https://www.sleepisland.org/en/"
  alternateJa="https://www.sleepisland.org/ja/"
  alternateEs="https://www.sleepisland.org/es/"
  alternatePt="https://www.sleepisland.org/pt/"
  schema={schema}
>
  <HomePage lang="ja" />
</BaseLayout>
